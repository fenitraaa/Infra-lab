[global]
workgroup       = LAB
server string   = NAS Lab Server
netbios name    = nas
security        = user
passdb backend  = tdbsam

obey pam restrictions = yes
pam password change   = yes
unix password sync    = yes

log file  = /var/log/samba/log.%m
log level = 1

[public]
path           = /srv/shares/public
valid users    = @linux @windows
read only      = no
browseable     = yes
create mask    = 0664
directory mask = 0775

[secure]
path           = /srv/shares/secure
valid users    = @admins
read only      = no
browseable     = no
create mask    = 0660
directory mask = 0770