[global]
workgroup = LAB
server string = NAS Lab Server
netbios name = nas
security = user
passdb backend = tdbsam

obey pam restrictions = yes
pam password change = yes
unix password sync = yes

log file = /var/log/samba/log.%m
log level = 1

[public]
path = /srv/shares/public
valid users = @linux @windows
read only = no
browseable = yes
create mask = 0664
directory mask = 0775
dfree command  = /usr/local/bin/dfree

[linuxuser]
path = /srv/shares/secure/linuxuser
valid users = linuxuser
read only = no
browseable = no
create mask = 0600
directory mask = 0700

[windowsuser]
path = /srv/shares/secure/windowsuser
valid users = windowsuser
read only = no
browseable = no
create mask = 0600
directory mask = 0700