storage "raft" {
  path = "/var/vault/data"
  node_id = "{{ inventory_hostname }}"
}

listener "tcp" {
  address = "0.0.0.0:8200"
  tls_cert_file = "/opt/vault/tls/vault.crt"
  tls_key_file = "/opt/vault/tls/vault.key"
}

api_addr = "https://{{ ansible_host }}:8200"
cluster_addr = "https://{{ ansible_host }}:8201"
ui = true
disable_mlock = true
