{
  "sudo_commands": {
    "services": [
      "/bin/systemctl status *",
      "/bin/systemctl restart *",
      "/bin/systemctl stop *",
      "/bin/systemctl start *"
    ],
    "logs": [
      "/usr/bin/journalctl",
      "/usr/bin/tail",
      "/usr/bin/cat"
    ],
    "reseau": [
      "/sbin/ip",
      "/usr/sbin/ss",
      "/usr/bin/netstat"
    ],
    "diagnostic": [
      "/usr/bin/top",
      "/usr/bin/htop",
      "/usr/bin/df",
      "/usr/bin/du",
      "/usr/bin/free"
    ],
    "roles": {
      "ansible": "ALL",
      "devops": ["services", "logs", "reseau", "diagnostic"]
    }
  },
  "users": [
    {
      "name": "ansible",
      "group": "ansible",
      "groups": [],
      "sudo": "ansible",
      "pub_key": "lab-ansible.pub"
    },
    {
      "name": "tojo",
      "group": "devops",
      "groups": ["adm"],
      "sudo": "devops",
      "pub_key": "lab-tojo.pub"
    }
  ]
}